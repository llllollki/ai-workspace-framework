# App repos — never commit application code into the framework repo
# Anchored to repo root (/) so nested ai-context/*/AssistedLivingHelp/ dirs are NOT excluded.
/AssistedLivingHelp/

# Claude Code: machine-local content (memory, history, audit log) is NOT portable.
# But the ENFORCEMENT SEATBELT is framework content and IS tracked (negations below).
# Anchored to repo root (/) so only top-level .claude/ is affected.
/.claude/*
!/.claude/settings.json
!/.claude/allow-list.json
!/.claude/egress-allowlist.txt
!/.claude/hooks/
!/.claude/skills/

# Environment and secrets
.env
.env.*
*.local

# Node / build output
node_modules/
.next/
dist/
build/
coverage/
*.log

# OS artifacts
.DS_Store
Thumbs.db

# Editor config
.vscode/
.idea/

# Not ignored (tracked by this repo):
# CLAUDE.md
# AGENTS.md
# ai-context/
# setup/
# README.md
# .gitignore
